{
  "name": "generic-lsp-proxy",
  "displayName": "Generic LSP Proxy",
  "description": "A flexible LSP proxy that dynamically forwards to any Language Server Protocol server",
  "version": "2.1.1",
  "publisher": "mjmorales",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "lsp",
    "language-server",
    "proxy",
    "generic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mjmorales/vscode-generic-lsp-proxy.git"
  },
  "bugs": {
    "url": "https://github.com/mjmorales/vscode-generic-lsp-proxy/issues"
  },
  "homepage": "https://github.com/mjmorales/vscode-generic-lsp-proxy#readme",
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.lsp-proxy.json",
    "workspaceContains:**/.vscode/lsp-proxy.json"
  ],
  "main": "./out/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Generic LSP Proxy",
      "properties": {
        "genericLspProxy.configPath": {
          "type": "string",
          "default": ".vscode/lsp-proxy.json",
          "description": "Path to LSP server mappings configuration file"
        },
        "genericLspProxy.enableDebugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging for LSP communication"
        }
      }
    },
    "commands": [
      {
        "command": "genericLspProxy.restart",
        "title": "Restart LSP Server",
        "category": "LSP Proxy"
      },
      {
        "command": "genericLspProxy.showActiveServers",
        "title": "Show Active LSP Servers",
        "category": "LSP Proxy"
      },
      {
        "command": "genericLspProxy.reloadConfig",
        "title": "Reload LSP Configuration",
        "category": "LSP Proxy"
      },
      {
        "command": "genericLspProxy.init",
        "title": "Initialize LSP Configuration",
        "category": "LSP Proxy"
      },
      {
        "command": "genericLspProxy.showDisabledServers",
        "title": "Show Disabled Servers",
        "category": "LSP Proxy"
      },
      {
        "command": "genericLspProxy.disable",
        "title": "Disable LSP Server",
        "category": "LSP Proxy"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "node ./out/test/runTest.js",
    "test:unit": "node ./out/test/unit-test-runner.js",
    "test:compile": "npm run compile && npm run test",
    "pretest": "npm run compile",
    "semantic-release": "semantic-release",
    "semantic-release:dry": "semantic-release --dry-run"
  },
  "dependencies": {
    "vscode-languageclient": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.19.43",
    "@types/sinon": "^17.0.3",
    "@types/vscode": "~1.91.0",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.6.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.6",
    "nyc": "^18.0.0",
    "prettier": "^3.9.4",
    "semantic-release": "^25.0.5",
    "semantic-release-vsce": "^5.6.4",
    "sinon": "^17.0.1",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
